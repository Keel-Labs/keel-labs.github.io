---
import { getLatestRelease, getStarCount } from '../lib/release';

const githubUrl = 'https://github.com/Keel-Labs/keel';

const release = await getLatestRelease();
const downloadUrl = release.dmgUrl;
const starCount = await getStarCount();
---

<section class="section">
  <div class="container-narrow">
    <div class="max-w-3xl">
      <h2 class="text-balance text-3xl font-semibold leading-[1.05] tracking-tight text-ink-900 dark:text-white md:text-5xl">
        Get Keel.
      </h2>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-600 dark:text-ink-300">
        Universal DMG for Apple Silicon and Intel. Open source. MIT licensed.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href={downloadUrl} class="btn-primary inline-flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 384 512" fill="currentColor" aria-hidden="true">
            <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z" />
          </svg>
          Download for macOS
        </a>
        <a href={githubUrl} class="btn-secondary inline-flex items-center gap-2" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.246l-7.416 4.167 1.48-8.279L0 9.306l8.332-1.151z" />
          </svg>
          {starCount && <span class="tabular-nums">{starCount}</span>}
          View and Star on GitHub
        </a>
        <a
          href="https://www.producthunt.com/products/keel-3?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-keel-3"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex"
        >
          <img
            alt="Keel - An AI assistant whose memory belongs to you | Product Hunt"
            width="250"
            height="54"
            src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1136403&theme=light&t=1778373120336"
          />
        </a>
      </div>
    </div>
  </div>
</section>
