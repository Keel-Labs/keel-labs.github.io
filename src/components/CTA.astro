---
import { getLatestRelease } from '../lib/release';

const githubUrl = 'https://github.com/Keel-Labs/keel';

const release = await getLatestRelease();
const downloadUrl = release.dmgUrl;
// Words rotated by the small client-side script below. Order kept in sync
// with the data-rotate attribute so the static HTML matches the first word
// shown to no-JS users / search crawlers.
const rotatingWords = ['memory', 'context', 'agents', 'AI', 'history', 'ideas'];
---

<section class="section section-alt">
  <div class="container-narrow">
    <div class="max-w-3xl">
      <h2 class="text-balance text-4xl font-semibold leading-[1.05] tracking-tight text-ink-900 dark:text-white md:text-6xl">
        Bring your{' '}
        <span
          class="rotating-word text-accent"
          data-rotate={rotatingWords.join('|')}
          aria-live="polite"
        >{rotatingWords[0]}</span>{' '}
        home.
      </h2>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-600 dark:text-ink-300">
        Universal DMG for Apple Silicon and Intel. Open source. MIT licensed.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a href={downloadUrl} class="btn-primary inline-flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 384 512" fill="currentColor" aria-hidden="true">
            <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z" />
          </svg>
          Download for macOS
        </a>
        <a href={githubUrl} class="btn-secondary" target="_blank" rel="noopener">
          View and Star on GitHub
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (reduceMotion.matches) return;

    const els = document.querySelectorAll<HTMLElement>('.rotating-word[data-rotate]');
    els.forEach((el) => {
      const words = (el.dataset.rotate || '').split('|').filter(Boolean);
      if (words.length < 2) return;

      // Reserve a modest min-width sized for the longest word in the list so
      // "home." doesn't slide around as words swap. Multiplier tuned for
      // bold display weight at this heading size.
      const longest = Math.max(...words.map((w) => w.length));
      el.style.display = 'inline-block';
      el.style.minWidth = `${longest * 0.48}em`;
      el.style.textAlign = 'center';
      el.style.transition = 'opacity 220ms ease, transform 220ms ease';
      el.style.willChange = 'opacity, transform';

      let idx = 0;
      const tick = () => {
        // fade out
        el.style.opacity = '0';
        el.style.transform = 'translateY(-6px)';
        window.setTimeout(() => {
          idx = (idx + 1) % words.length;
          el.textContent = words[idx];
          // reset to bottom, then fade in
          el.style.transform = 'translateY(6px)';
          // force reflow so the next transition kicks in
          void el.offsetWidth;
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, 240);
      };

      let timer = window.setInterval(tick, 2200);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          window.clearInterval(timer);
        } else {
          timer = window.setInterval(tick, 2200);
        }
      });
    });
  })();
</script>
