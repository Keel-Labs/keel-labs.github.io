---
import { getLatestRelease } from '../lib/release';

const navLinks = [
  { href: '#how', label: 'How it works' },
  { href: '#principles', label: 'Principles' },
  { href: '#use-cases', label: 'Use cases' },
  { href: '#features', label: 'Features' },
  { href: '#about', label: 'About' },
];

// Fetch the live star count at build time. Re-runs on every push to main
// (the deploy workflow does a fresh build), and falls back gracefully if
// GitHub's API rate-limits or errors.
let starCount = '';
try {
  const headers: Record<string, string> = { Accept: 'application/vnd.github+json' };
  const token = typeof process !== 'undefined' ? process.env?.GITHUB_TOKEN : '';
  if (token) headers.Authorization = `Bearer ${token}`;
  const res = await fetch('https://api.github.com/repos/Keel-Labs/keel', { headers });
  if (res.ok) {
    const data = await res.json();
    if (typeof data.stargazers_count === 'number') {
      starCount = new Intl.NumberFormat('en-US').format(data.stargazers_count);
    }
  }
} catch {
  // ignore — render the button without a count
}

const ghRepoUrl = 'https://github.com/Keel-Labs/keel';
const ghStargazersUrl = `${ghRepoUrl}/stargazers`;
const sponsorUrl = 'https://github.com/sponsors/medha';

const release = await getLatestRelease();
const downloadUrl = release.dmgUrl;
---

<header class="sticky top-0 z-40 w-full border-b border-ink-200/70 bg-ink-50/80 backdrop-blur dark:border-ink-800/60 dark:bg-ink-950/80">
  <div class="container-narrow relative flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center" aria-label="Keel">
      <img src="/keel-logo.png" alt="Keel" class="h-9 w-auto" />
    </a>

    <nav class="absolute left-1/2 top-1/2 hidden -translate-x-1/2 -translate-y-1/2 items-center gap-7 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="whitespace-nowrap text-sm text-ink-600 transition hover:text-accent dark:text-ink-300 dark:hover:text-accent"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={ghStargazersUrl}
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-1.5 rounded-full border border-ink-200 bg-white px-3 py-1.5 text-xs font-medium text-ink-700 transition hover:border-ink-300 hover:text-ink-900 dark:border-ink-700 dark:bg-ink-900 dark:text-ink-200 dark:hover:border-ink-600 dark:hover:text-white sm:inline-flex"
        aria-label={starCount ? `${starCount} stars on GitHub` : 'Star Keel on GitHub'}
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.246l-7.416 4.167 1.48-8.279L0 9.306l8.332-1.151z" />
        </svg>
        {starCount ? (
          <>
            <span class="tabular-nums">{starCount}</span>
            <span class="text-ink-500 dark:text-ink-400">stars</span>
          </>
        ) : (
          <span>Star</span>
        )}
      </a>

      <a
        href={sponsorUrl}
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-1.5 rounded-full border border-ink-200 bg-white px-3 py-1.5 text-xs font-medium text-ink-700 transition hover:border-ink-300 hover:text-ink-900 dark:border-ink-700 dark:bg-ink-900 dark:text-ink-200 dark:hover:border-ink-600 dark:hover:text-white sm:inline-flex"
        aria-label="Sponsor Keel — buy me a coffee"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 8h1a4 4 0 010 8h-1" />
          <path d="M3 8h14v9a4 4 0 01-4 4H7a4 4 0 01-4-4V8z" />
          <line x1="6" y1="2" x2="6" y2="4" />
          <line x1="10" y1="2" x2="10" y2="4" />
          <line x1="14" y1="2" x2="14" y2="4" />
        </svg>
        <span>Sponsor</span>
      </a>

      <a href={downloadUrl} class="btn-primary inline-flex items-center gap-1.5 !py-2 !px-4 text-xs">
        <svg width="13" height="13" viewBox="0 0 384 512" fill="currentColor" aria-hidden="true">
          <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z" />
        </svg>
        Download
      </a>
    </div>
  </div>
</header>
