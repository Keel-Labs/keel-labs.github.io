---
const navLinks = [
  { href: '#how', label: 'How it works' },
  { href: '#features', label: 'Features' },
  { href: '#privacy', label: 'Privacy' },
  { href: 'https://github.com/Keel-Labs/keel', label: 'GitHub', external: true },
];
---

<header class="sticky top-0 z-40 w-full border-b border-ink-200/70 bg-ink-50/80 backdrop-blur dark:border-ink-800/60 dark:bg-ink-950/80">
  <div class="container-narrow flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2.5">
      <img src="/keel-badge.png" alt="" width="26" height="26" class="rounded" />
      <span class="text-base font-semibold tracking-tight">Keel</span>
    </a>
    <nav class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-ink-600 transition hover:text-accent dark:text-ink-300 dark:hover:text-accent"
          {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <a
      href="https://github.com/Keel-Labs/keel/releases/latest"
      class="btn-primary !py-2 !px-4 text-xs"
    >
      Download
    </a>
  </div>
</header>
