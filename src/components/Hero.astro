---
// TODO: replace placeholder Loom URL once a fresh demo is recorded.
const demoUrl = 'https://www.loom.com/share/29c1407fc2944b1fb5c6c1bbc953831b';
const downloadUrl = 'https://github.com/Keel-Labs/keel/releases/latest/download/Keel-0.2.0-mac.dmg';
const githubUrl = 'https://github.com/Keel-Labs/keel';
---

<section class="relative">
  <div class="container-narrow pt-24 pb-20 md:pt-36 md:pb-32">
    <div class="max-w-3xl">
      <p class="eyebrow mb-6">Local-first AI for macOS</p>
      <h1 class="text-balance text-5xl font-semibold leading-[1.05] tracking-tight text-ink-900 dark:text-white md:text-7xl">
        An AI assistant whose memory belongs to you.
      </h1>
      <p class="mt-7 max-w-2xl text-pretty text-lg leading-relaxed text-ink-600 dark:text-ink-300 md:text-xl">
        Local-first Mac app. Plain markdown on your disk. Swap Claude, GPT, OpenRouter, or Ollama anytime — your context stays.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3">
        <a href={downloadUrl} class="btn-primary">Download for macOS</a>
        <a href={githubUrl} class="btn-text" target="_blank" rel="noopener">
          View on GitHub <span aria-hidden="true">&rarr;</span>
        </a>
        <a href={demoUrl} class="btn-text" target="_blank" rel="noopener">
          Watch demo <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
      <p class="mt-5 text-xs text-ink-500 dark:text-ink-400">
        Open source (MIT). No telemetry. No account.
      </p>
    </div>
  </div>
</section>
