---
import { getLatestRelease } from '../lib/release';

const demoEmbedUrl = 'https://www.loom.com/embed/29c1407fc2944b1fb5c6c1bbc953831b';
const demoPosterUrl = '/keel-demo-poster.jpg';
const githubUrl = 'https://github.com/Keel-Labs/keel';

const release = await getLatestRelease();
const downloadUrl = release.dmgUrl;
---

<section class="relative overflow-hidden">
  <canvas
    id="hero-particles"
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 hidden h-full w-full lg:block"
  ></canvas>

  <div class="container-narrow relative pt-10 pb-12 md:pt-14 md:pb-16">
    <div class="relative mx-auto flex max-w-4xl flex-col items-center text-center">
      <span class="eyebrow rounded-full bg-accent/10 px-4 py-1.5 text-accent">
        Now available — {release.tag}
      </span>

      <img
        src="/keel-logo.png"
        alt="Keel"
        class="mt-5 h-auto w-full max-w-[18rem] md:max-w-[24rem] lg:max-w-[28rem]"
      />

      <p class="mt-5 max-w-2xl text-pretty text-base leading-relaxed text-ink-600 dark:text-ink-300 md:text-lg">
        <strong class="font-bold text-ink-900 dark:text-white">An AI assistant whose memory belongs to you.</strong> Local-first Mac app. Plain markdown on your disk. Swap Claude, GPT, OpenRouter, or Ollama anytime — your context stays.
      </p>

      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a href={downloadUrl} class="btn-primary">Download for macOS</a>
        <a href={githubUrl} class="btn-secondary" target="_blank" rel="noopener">
          View and Star on GitHub
        </a>
      </div>

      <p class="mt-4 text-xs text-ink-500 dark:text-ink-400">
        Open source (MIT). No telemetry. No account.
      </p>

      <button
        type="button"
        class="js-watch-demo demo-poster mt-10 w-full max-w-3xl"
        aria-label="Watch Keel demo"
      >
        <span class="demo-poster__frame" style={`background-image: url(${demoPosterUrl})`}>
          <span class="demo-poster__play" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z" />
            </svg>
          </span>
        </span>
      </button>
    </div>
  </div>

  <dialog id="demo-modal" class="demo-modal">
    <button id="close-demo-btn" type="button" class="demo-modal__close" aria-label="Close demo">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <div class="demo-modal__embed">
      <iframe
        id="demo-iframe"
        data-src={demoEmbedUrl}
        title="Keel demo video"
        allow="autoplay; fullscreen"
        allowfullscreen
      ></iframe>
    </div>
  </dialog>
</section>

<script>
  (() => {
    const canvas = document.getElementById('hero-particles') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    // Origami sailboats — each boat drifts horizontally, bobs on an
    // invisible waterline (sine wave on y), and rolls slightly with the
    // bob so it reads as floating rather than sliding.
    type Boat = {
      x: number;
      baseY: number;
      vx: number;       // px/sec
      size: number;     // sail-tip-to-waterline radius in px
      alpha: number;
      bobAmp: number;   // px
      bobFreq: number;  // rad/sec
      bobPhase: number; // rad
    };
    let boats: Boat[] = [];
    let raf = 0;
    let running = false;
    let lastT = 0;
    let elapsed = 0;
    let w = 0, h = 0;
    // Horizontal sailing band centered on the hero logo. Boats drift
    // left-to-right across the canvas inside this band, fading out
    // where they would otherwise draw over the wordmark itself.
    let bandTop = 0, bandBottom = 0;
    let bandLeft = 0, bandRight = 0;
    let logoLeft = 0, logoRight = 0, logoTop = 0, logoBottom = 0;

    const dpr = () => Math.min(window.devicePixelRatio || 1, 2);

    function measureHalo() {
      const heroLogo = document.querySelector<HTMLImageElement>(
        'section.relative.overflow-hidden img[src="/keel-logo.png"]'
      );
      const subhead = document.querySelector<HTMLParagraphElement>(
        'section.relative.overflow-hidden p.mt-5'
      );
      const canvasRect = canvas!.getBoundingClientRect();
      if (heroLogo) {
        const r = heroLogo.getBoundingClientRect();
        const cy = (r.top + r.bottom) / 2 - canvasRect.top;
        const halfH = r.height / 2;
        // Asymmetric: extend the band well above the logo (covers the
        // eyebrow area) and stop right at the logo's bottom edge so
        // boats never sail into the subhead.
        bandTop = cy - halfH * 2.6;
        bandBottom = cy + halfH * 1.0;
        // Hard clamp: never past 30px above the subhead top, even if
        // the logo is unusually tall at this viewport.
        if (subhead) {
          const subTop = subhead.getBoundingClientRect().top - canvasRect.top;
          bandBottom = Math.min(bandBottom, subTop - 30);
        }
        logoLeft = r.left - canvasRect.left;
        logoRight = r.right - canvasRect.left;
        logoTop = r.top - canvasRect.top;
        logoBottom = r.bottom - canvasRect.top;
        // Horizontal halo: boats fade in a few inches left of the
        // logo and fade out symmetrically on the right. Margin scales
        // with the logo width but has a minimum so it still feels
        // natural at small viewports.
        const haloMargin = Math.max(180, r.width * 0.55);
        bandLeft = logoLeft - haloMargin;
        bandRight = logoRight + haloMargin;
      } else {
        bandTop = h * 0.18;
        bandBottom = h * 0.55;
        logoLeft = w * 0.3;
        logoRight = w * 0.7;
        logoTop = h * 0.25;
        logoBottom = h * 0.5;
        bandLeft = w * 0.15;
        bandRight = w * 0.85;
      }
    }

    function resize() {
      const rect = canvas!.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      const r = dpr();
      canvas!.width = Math.floor(w * r);
      canvas!.height = Math.floor(h * r);
      ctx!.setTransform(r, 0, 0, r, 0, 0);
      measureHalo();
      seed();
    }

    function seed() {
      // Density scales with band area — a wide hero gets more boats
      // so the spacing stays roughly constant.
      const bandH = Math.max(1, bandBottom - bandTop);
      const count = Math.max(6, Math.min(20, Math.round((w * bandH) / 22000)));
      boats = [];
      for (let i = 0; i < count; i++) boats.push(spawn(true));
    }

    function spawn(initial: boolean): Boat {
      const size = 5 + Math.random() * 4;
      // Stay inside the horizontal halo: respawn just past the halo's
      // left edge so the boat fades back in on entry; initial seed
      // distributes across the halo so it starts populated.
      const x = initial
        ? bandLeft + Math.random() * (bandRight - bandLeft)
        : bandLeft - size * 3 - Math.random() * 30;
      const baseY = bandTop + Math.random() * (bandBottom - bandTop);
      return {
        x,
        baseY,
        vx: 4 + Math.random() * 7,
        size,
        alpha: 0.22 + Math.random() * 0.22,
        bobAmp: 1.5 + Math.random() * 2.5,
        bobFreq: 0.6 + Math.random() * 0.8,
        bobPhase: Math.random() * Math.PI * 2,
      };
    }

    function drawBoat(b: Boat, t: number) {
      const { x, baseY, size, alpha, bobAmp, bobFreq, bobPhase } = b;
      const bob = Math.sin(t * bobFreq + bobPhase);
      const y = baseY + bob * bobAmp;
      const roll = bob * 0.08;

      // Soft fade at the top and bottom of the band so boats don't
      // pop in/out at the edges of the sailing strip.
      const bandFadeH = Math.max(20, (bandBottom - bandTop) * 0.18);
      const topFade = Math.min(1, Math.max(0, (y - bandTop) / bandFadeH));
      const botFade = Math.min(1, Math.max(0, (bandBottom - y) / bandFadeH));
      // Horizontal halo: sin bell so boats fade in on the left, peak
      // around the logo, and fade out symmetrically on the right.
      const halfHaloW = (bandRight - bandLeft) / 2;
      const dxFromCenter = Math.abs(x - (bandLeft + halfHaloW));
      const xFade = dxFromCenter >= halfHaloW
        ? 0
        : Math.sin((1 - dxFromCenter / halfHaloW) * Math.PI / 2);
      // Hide boats over the wordmark itself, with a small blur margin
      // so they fade into / out of the logo area rather than disappear.
      const margin = 18;
      let logoFade = 1;
      if (
        x + size * 1.4 > logoLeft - margin &&
        x - size * 1.4 < logoRight + margin &&
        y + size * 0.6 > logoTop - margin &&
        y - size * 2.0 < logoBottom + margin
      ) {
        const dxL = (logoLeft - margin) - (x + size * 1.4);
        const dxR = (x - size * 1.4) - (logoRight + margin);
        const closestX = Math.max(dxL, dxR);
        const dyT = (logoTop - margin) - (y + size * 0.6);
        const dyB = (y - size * 2.0) - (logoBottom + margin);
        const closestY = Math.max(dyT, dyB);
        const closest = Math.max(closestX, closestY);
        logoFade = Math.min(1, Math.max(0, (closest + margin) / margin));
      }
      const a = alpha * topFade * botFade * logoFade * xFade;
      if (a <= 0.01) return;

      ctx!.save();
      ctx!.translate(x, y);
      ctx!.rotate(roll);

      const fill = `rgba(207, 122, 92, ${a})`;
      ctx!.fillStyle = fill;

      // Hull: trapezoid sitting on the waterline (y=0). Wider at the
      // top, narrower at the bottom — a folded-paper boat profile.
      ctx!.beginPath();
      ctx!.moveTo(-1.4 * size, 0);
      ctx!.lineTo(1.4 * size, 0);
      ctx!.lineTo(0.85 * size, 0.55 * size);
      ctx!.lineTo(-0.85 * size, 0.55 * size);
      ctx!.closePath();
      ctx!.fill();

      // Sail: right triangle leaning forward. Vertical mast on the
      // right, hypotenuse from tip down to the hull's left-top corner.
      ctx!.beginPath();
      ctx!.moveTo(0, -2.0 * size);   // sail tip (top)
      ctx!.lineTo(0, -0.05 * size);  // mast base, slight overlap with hull
      ctx!.lineTo(-1.1 * size, -0.05 * size); // hull-top-left
      ctx!.closePath();
      ctx!.fill();

      ctx!.restore();
    }

    function frame(t: number) {
      if (!running) return;
      const dt = lastT ? Math.min(0.05, (t - lastT) / 1000) : 0.016;
      lastT = t;
      elapsed += dt;
      ctx!.clearRect(0, 0, w, h);
      for (const b of boats) {
        b.x += b.vx * dt;
        // Once a boat passes the halo's right edge it has fully faded
        // out — respawn it just past the left edge with a fresh
        // waterline so it fades back in on entry.
        if (b.x > bandRight + b.size * 3) Object.assign(b, spawn(false));
        drawBoat(b, elapsed);
      }
      raf = requestAnimationFrame(frame);
    }

    function start() {
      if (running || reduceMotion.matches) return;
      running = true;
      lastT = 0;
      raf = requestAnimationFrame(frame);
    }

    function stop() {
      running = false;
      if (raf) cancelAnimationFrame(raf);
    }

    function staticRender() {
      ctx!.clearRect(0, 0, w, h);
      for (const b of boats) drawBoat(b, 0);
    }

    resize();
    window.addEventListener('resize', () => {
      resize();
      if (reduceMotion.matches) staticRender();
    });
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop(); else start();
    });
    reduceMotion.addEventListener?.('change', () => {
      if (reduceMotion.matches) { stop(); staticRender(); } else start();
    });

    if (reduceMotion.matches) staticRender(); else start();
  })();

  // Demo modal — load the iframe lazily on first open so the page doesn't
  // pay for a Loom embed unless the user clicks Watch Demo.
  (() => {
    const triggers = document.querySelectorAll<HTMLButtonElement>('.js-watch-demo');
    const closeBtn = document.getElementById('close-demo-btn') as HTMLButtonElement | null;
    const modal = document.getElementById('demo-modal') as HTMLDialogElement | null;
    const iframe = document.getElementById('demo-iframe') as HTMLIFrameElement | null;
    if (!triggers.length || !closeBtn || !modal || !iframe) return;

    const open = () => {
      const src = iframe.dataset.src || '';
      if (iframe.getAttribute('src') !== src && src) {
        iframe.setAttribute('src', src);
      }
      if (typeof modal.showModal === 'function') modal.showModal();
      else modal.setAttribute('open', '');
    };
    triggers.forEach((t) => t.addEventListener('click', open));

    const close = () => {
      if (typeof modal.close === 'function') modal.close();
      else modal.removeAttribute('open');
      // Stop the video by removing src so it doesn't keep playing in background.
      iframe.removeAttribute('src');
    };
    closeBtn.addEventListener('click', close);

    // Click on backdrop closes the modal.
    modal.addEventListener('click', (e) => {
      if (e.target === modal) close();
    });
  })();
</script>
