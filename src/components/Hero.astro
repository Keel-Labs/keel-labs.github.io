---
const demoEmbedUrl = 'https://www.loom.com/embed/29c1407fc2944b1fb5c6c1bbc953831b';
const demoPosterUrl = '/keel-demo-poster.jpg';
const downloadUrl = 'https://github.com/Keel-Labs/keel/releases/latest/download/Keel-0.2.0-mac.dmg';
const githubUrl = 'https://github.com/Keel-Labs/keel';
---

<section class="relative overflow-hidden">
  <canvas
    id="hero-particles"
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 hidden h-full w-full lg:block"
  ></canvas>

  <div class="container-narrow relative pt-10 pb-12 md:pt-14 md:pb-16">
    <div class="relative mx-auto flex max-w-4xl flex-col items-center text-center">
      <span class="eyebrow rounded-full bg-accent/10 px-4 py-1.5 text-accent">
        Now available — v0.2.0
      </span>

      <img
        src="/keel-logo.png"
        alt="Keel"
        class="mt-5 h-auto w-full max-w-[18rem] md:max-w-[24rem] lg:max-w-[28rem]"
      />

      <p class="mt-5 max-w-2xl text-pretty text-base leading-relaxed text-ink-600 dark:text-ink-300 md:text-lg">
        <strong class="font-bold text-ink-900 dark:text-white">An AI assistant whose memory belongs to you.</strong> Local-first Mac app. Plain markdown on your disk. Swap Claude, GPT, OpenRouter, or Ollama anytime — your context stays.
      </p>

      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a href={downloadUrl} class="btn-primary">Download for macOS</a>
        <a href={githubUrl} class="btn-secondary" target="_blank" rel="noopener">
          View and Star on GitHub
        </a>
      </div>

      <p class="mt-4 text-xs text-ink-500 dark:text-ink-400">
        Open source (MIT). No telemetry. No account.
      </p>

      <button
        type="button"
        class="js-watch-demo demo-poster mt-10 w-full max-w-3xl"
        aria-label="Watch Keel demo"
      >
        <span class="demo-poster__frame" style={`background-image: url(${demoPosterUrl})`}>
          <span class="demo-poster__play" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z" />
            </svg>
          </span>
        </span>
      </button>
    </div>
  </div>

  <dialog id="demo-modal" class="demo-modal">
    <button id="close-demo-btn" type="button" class="demo-modal__close" aria-label="Close demo">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <div class="demo-modal__embed">
      <iframe
        id="demo-iframe"
        data-src={demoEmbedUrl}
        title="Keel demo video"
        allow="autoplay; fullscreen"
        allowfullscreen
      ></iframe>
    </div>
  </dialog>
</section>

<script>
  (() => {
    const canvas = document.getElementById('hero-particles') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    // Origami sailboats — each boat drifts horizontally, bobs on an
    // invisible waterline (sine wave on y), and rolls slightly with the
    // bob so it reads as floating rather than sliding.
    type Boat = {
      x: number;
      baseY: number;
      vx: number;       // px/sec
      size: number;     // sail-tip-to-waterline radius in px
      alpha: number;
      bobAmp: number;   // px
      bobFreq: number;  // rad/sec
      bobPhase: number; // rad
    };
    let boats: Boat[] = [];
    let raf = 0;
    let running = false;
    let lastT = 0;
    let elapsed = 0;
    let w = 0, h = 0;

    const dpr = () => Math.min(window.devicePixelRatio || 1, 2);

    function resize() {
      const rect = canvas!.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      const r = dpr();
      canvas!.width = Math.floor(w * r);
      canvas!.height = Math.floor(h * r);
      ctx!.setTransform(r, 0, 0, r, 0, 0);
      seed();
    }

    function seed() {
      const area = w * h;
      // Sailboats are larger and more recognisable than triangles, so
      // density is lower — too many feels busy.
      const count = Math.max(8, Math.min(28, Math.round(area / 36000)));
      boats = [];
      for (let i = 0; i < count; i++) boats.push(spawn(true));
    }

    function spawn(initial: boolean): Boat {
      const size = 9 + Math.random() * 9;
      const dir = Math.random() < 0.5 ? -1 : 1;
      const x = initial ? Math.random() * w : (dir > 0 ? -size * 3 : w + size * 3);
      const baseY = size * 2.5 + Math.random() * (h - size * 5);
      return {
        x,
        baseY,
        vx: dir * (4 + Math.random() * 8),
        size,
        alpha: 0.18 + Math.random() * 0.22,
        bobAmp: 2 + Math.random() * 4,
        bobFreq: 0.6 + Math.random() * 0.8,
        bobPhase: Math.random() * Math.PI * 2,
      };
    }

    function drawBoat(b: Boat, t: number) {
      const { x, baseY, size, alpha, bobAmp, bobFreq, bobPhase } = b;
      const bob = Math.sin(t * bobFreq + bobPhase);
      const y = baseY + bob * bobAmp;
      const roll = bob * 0.06; // small tilt synced with the bob

      // Fade boats inside a centered "no-go" radius so they don't crowd
      // the logo and headline.
      const cx = w / 2;
      const cy = h / 2;
      const dx = x - cx;
      const dy = y - cy;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const safeRadius = Math.min(w, h) * 0.32;
      const fade = Math.min(1, Math.max(0, (dist - safeRadius) / (Math.min(w, h) * 0.18)));
      const a = alpha * fade;
      if (a <= 0.01) return;

      ctx!.save();
      ctx!.translate(x, y);
      ctx!.rotate(roll);

      const fill = `rgba(207, 122, 92, ${a})`;
      ctx!.fillStyle = fill;

      // Hull: trapezoid sitting on the waterline (y=0). Wider at the
      // top, narrower at the bottom — a folded-paper boat profile.
      ctx!.beginPath();
      ctx!.moveTo(-1.4 * size, 0);
      ctx!.lineTo(1.4 * size, 0);
      ctx!.lineTo(0.85 * size, 0.55 * size);
      ctx!.lineTo(-0.85 * size, 0.55 * size);
      ctx!.closePath();
      ctx!.fill();

      // Sail: right triangle leaning forward. Vertical mast on the
      // right, hypotenuse from tip down to the hull's left-top corner.
      ctx!.beginPath();
      ctx!.moveTo(0, -2.0 * size);   // sail tip (top)
      ctx!.lineTo(0, -0.05 * size);  // mast base, slight overlap with hull
      ctx!.lineTo(-1.1 * size, -0.05 * size); // hull-top-left
      ctx!.closePath();
      ctx!.fill();

      ctx!.restore();
    }

    function frame(t: number) {
      if (!running) return;
      const dt = lastT ? Math.min(0.05, (t - lastT) / 1000) : 0.016;
      lastT = t;
      elapsed += dt;
      ctx!.clearRect(0, 0, w, h);
      for (const b of boats) {
        b.x += b.vx * dt;
        // Wrap around horizontally so a boat that drifts off one edge
        // re-enters from the opposite edge with a fresh waterline.
        if (b.vx > 0 && b.x > w + b.size * 3) Object.assign(b, spawn(false), { x: -b.size * 3 });
        else if (b.vx < 0 && b.x < -b.size * 3) Object.assign(b, spawn(false), { x: w + b.size * 3 });
        drawBoat(b, elapsed);
      }
      raf = requestAnimationFrame(frame);
    }

    function start() {
      if (running || reduceMotion.matches) return;
      running = true;
      lastT = 0;
      raf = requestAnimationFrame(frame);
    }

    function stop() {
      running = false;
      if (raf) cancelAnimationFrame(raf);
    }

    function staticRender() {
      ctx!.clearRect(0, 0, w, h);
      for (const b of boats) drawBoat(b, 0);
    }

    resize();
    window.addEventListener('resize', () => {
      resize();
      if (reduceMotion.matches) staticRender();
    });
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop(); else start();
    });
    reduceMotion.addEventListener?.('change', () => {
      if (reduceMotion.matches) { stop(); staticRender(); } else start();
    });

    if (reduceMotion.matches) staticRender(); else start();
  })();

  // Demo modal — load the iframe lazily on first open so the page doesn't
  // pay for a Loom embed unless the user clicks Watch Demo.
  (() => {
    const triggers = document.querySelectorAll<HTMLButtonElement>('.js-watch-demo');
    const closeBtn = document.getElementById('close-demo-btn') as HTMLButtonElement | null;
    const modal = document.getElementById('demo-modal') as HTMLDialogElement | null;
    const iframe = document.getElementById('demo-iframe') as HTMLIFrameElement | null;
    if (!triggers.length || !closeBtn || !modal || !iframe) return;

    const open = () => {
      const src = iframe.dataset.src || '';
      if (iframe.getAttribute('src') !== src && src) {
        iframe.setAttribute('src', src);
      }
      if (typeof modal.showModal === 'function') modal.showModal();
      else modal.setAttribute('open', '');
    };
    triggers.forEach((t) => t.addEventListener('click', open));

    const close = () => {
      if (typeof modal.close === 'function') modal.close();
      else modal.removeAttribute('open');
      // Stop the video by removing src so it doesn't keep playing in background.
      iframe.removeAttribute('src');
    };
    closeBtn.addEventListener('click', close);

    // Click on backdrop closes the modal.
    modal.addEventListener('click', (e) => {
      if (e.target === modal) close();
    });
  })();
</script>
