---
const features = [
  {
    title: 'Auto-capture',
    body: 'When a chat produces something worth keeping — a decision, a fact, a new task — Keel quietly saves it back into your workspace.',
  },
  {
    title: 'Wiki bases',
    body: 'Turn any project folder into a structured, queryable knowledge base. Markdown and PDFs in; clean compiled context out.',
  },
  {
    title: 'Dashboard',
    body: 'Open tasks, reminders, the morning brief, weather, and recent activity — surfaced on launch so the day starts with momentum.',
  },
  {
    title: 'Tasks & reminders',
    body: 'First-class to-dos backed by markdown, with due dates, projects, and time-based reminders that fire as desktop notifications.',
  },
  {
    title: 'Meeting transcription',
    body: 'Record or import audio. Local Whisper transcribes; Keel writes decisions, action items, and attendees back into the right project.',
  },
  {
    title: 'Voice input',
    body: 'Speak instead of type, using local Whisper or OpenAI\'s API.',
  },
  {
    title: 'Scheduled jobs',
    body: 'Run any prompt or workflow on a recurring schedule — daily digests, weekly reviews, custom check-ins — captured back to disk.',
  },
  {
    title: 'Google + X integrations',
    body: 'Sync Calendar events into context, read and export Google Docs, sync X bookmarks into a wiki, or publish posts from chat.',
  },
];
---

<section id="features" class="section bg-ink-50/60 dark:bg-ink-900/30">
  <div class="container-narrow">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">Features</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
        Everything a chief-of-staff would do, on your machine.
      </h2>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((f) => (
        <div class="rounded-xl border border-ink-200 bg-white p-6 transition hover:border-ink-300 dark:border-ink-800 dark:bg-ink-950 dark:hover:border-ink-700">
          <h3 class="text-base font-semibold tracking-tight">{f.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-600 dark:text-ink-300">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
