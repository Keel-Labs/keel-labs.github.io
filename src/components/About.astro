---
import { getMaintainer } from '../lib/release';

const m = await getMaintainer();
const sponsorUrl = 'https://github.com/sponsors/medha';
---

<section id="about" class="section">
  <div class="container-narrow">
    <div class="max-w-3xl">
      <div class="flex items-baseline gap-5">
        <span class="section-num">05</span>
        <span class="eyebrow">About</span>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center gap-8 text-center md:flex-row md:items-start md:gap-12 md:text-left">
      <a
        href={m.profileUrl}
        target="_blank"
        rel="noopener"
        class="block shrink-0 transition hover:opacity-90"
        aria-label={`${m.name} on GitHub`}
      >
        <img
          src={m.avatarUrl}
          alt={m.name}
          width="160"
          height="160"
          class="h-40 w-40 rounded-full border border-ink-200 object-cover shadow-sm dark:border-ink-800"
        />
      </a>

      <div class="max-w-2xl">
        <h2 class="text-3xl font-semibold tracking-tight text-ink-900 dark:text-white md:text-4xl">
          {m.name}
        </h2>
        {m.bio && (
          <p class="mt-4 text-lg leading-relaxed text-ink-700 dark:text-ink-200">
            {m.bio}
          </p>
        )}
        {(m.location || m.blog) && (
          <p class="mt-3 text-sm text-ink-500 dark:text-ink-400">
            {m.location}
            {m.location && m.blog ? ' · ' : ''}
            {m.blog && (
              <a
                href={m.blog.startsWith('http') ? m.blog : `https://${m.blog}`}
                target="_blank"
                rel="noopener"
                class="hover:text-accent"
              >
                {m.blog.replace(/^https?:\/\//, '')}
              </a>
            )}
          </p>
        )}
        <div class="mt-6 flex flex-wrap items-center justify-center gap-3 md:justify-start">
          <a href={m.profileUrl} target="_blank" rel="noopener" class="btn-secondary">
            @{m.login} on GitHub
          </a>
          <a href={sponsorUrl} target="_blank" rel="noopener" class="btn-text inline-flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17 8h1a4 4 0 010 8h-1" />
              <path d="M3 8h14v9a4 4 0 01-4 4H7a4 4 0 01-4-4V8z" />
              <line x1="6" y1="2" x2="6" y2="4" />
              <line x1="10" y1="2" x2="10" y2="4" />
              <line x1="14" y1="2" x2="14" y2="4" />
            </svg>
            Buy me a coffee <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
