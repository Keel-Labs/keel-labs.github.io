---
const links = [
  { href: 'https://github.com/Keel-Labs/keel/blob/main/PRIVACY.md', label: 'Privacy' },
  { href: 'https://github.com/Keel-Labs/keel/blob/main/TERMS.md', label: 'Terms' },
  { href: 'https://github.com/Keel-Labs/keel/blob/main/LICENSE', label: 'License (MIT)' },
  { href: 'https://github.com/sponsors/medha', label: 'Sponsor' },
  { href: 'https://keel.fider.io', label: 'Fider' },
  { href: 'https://github.com/Keel-Labs/keel/releases', label: 'Releases' },
];
---

<footer class="border-t border-ink-200 py-12 dark:border-ink-800">
  <div class="container-narrow flex flex-col items-center justify-between gap-6 md:flex-row">
    <div class="flex items-center gap-2.5">
      <img src="/keel-badge.png" alt="" class="h-7 w-auto rounded" />
      <span class="text-sm font-medium text-ink-700 dark:text-ink-300">Keel</span>
      <span class="text-sm text-ink-400 dark:text-ink-500">— built by one person, MIT licensed.</span>
    </div>
    <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
      {links.map((l) => (
        <a
          href={l.href}
          target="_blank"
          rel="noopener"
          class="text-sm text-ink-600 transition hover:text-ink-900 dark:text-ink-400 dark:hover:text-white"
        >
          {l.label}
        </a>
      ))}
    </nav>
  </div>
</footer>
