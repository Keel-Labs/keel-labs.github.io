---
const nodes = [
  {
    title: 'Markdown workspace',
    body: 'A folder on your disk — typically ~/Keel — full of plain markdown. Project notes, daily logs, wiki bases, tasks. Edit it in any editor. Back it up yourself.',
    icon: 'folder',
  },
  {
    title: 'Keel context engine',
    body: 'Indexes your workspace, assembles relevant context for every conversation, and writes captures, decisions, and tasks back as markdown.',
    icon: 'cpu',
  },
  {
    title: 'Your chosen LLM',
    body: 'Claude, GPT, OpenRouter, or a local model via Ollama. Swap providers in settings; fall back automatically when one is down.',
    icon: 'sparkles',
  },
];
---

<section id="how" class="section">
  <div class="container-narrow">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">How it works</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
        Your context stays. The model is just a tenant.
      </h2>
      <p class="mt-4 text-lg text-ink-600 dark:text-ink-300">
        Three pieces. Two of them belong to you.
      </p>
    </div>

    <div class="relative mt-14 grid gap-6 md:grid-cols-3">
      <div class="pointer-events-none absolute left-0 right-0 top-12 hidden h-px bg-gradient-to-r from-transparent via-ink-300 to-transparent md:block dark:via-ink-700"></div>
      {nodes.map((n, i) => (
        <div class="relative rounded-2xl border border-ink-200 bg-white p-7 dark:border-ink-800 dark:bg-ink-900">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 text-accent">
            <span class="text-base font-semibold">{i + 1}</span>
          </div>
          <h3 class="mt-5 text-lg font-semibold">{n.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-600 dark:text-ink-300">{n.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
