---
const pillars = [
  {
    title: 'Own your context',
    body: 'Your notes, captures, projects, and history live in plain markdown in a folder you control. Not a database row inside someone else\'s cloud.',
  },
  {
    title: 'Pick your model',
    body: 'Claude today, GPT tomorrow, a local Llama on a flight. The assistant changes; your brain doesn\'t.',
  },
  {
    title: 'Local-first',
    body: 'No telemetry. No account. No server. Your workspace never leaves your machine unless you explicitly ask it to.',
  },
];
---

<section id="principles" class="section">
  <div class="container-narrow">
    <div class="max-w-3xl">
      <div class="flex items-baseline gap-5">
        <span class="section-num">04</span>
        <span class="eyebrow">Principles</span>
      </div>
      <h2 class="mt-8 text-3xl font-semibold tracking-tight text-ink-900 dark:text-white md:text-5xl">
        Three commitments that don't bend.
      </h2>
    </div>

    <div class="mt-16 grid gap-10 md:grid-cols-3">
      {pillars.map((p, i) => (
        <div class="border-t border-ink-300 pt-6 dark:border-ink-700">
          <span class="text-xs font-mono text-accent">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="mt-4 text-xl font-semibold tracking-tight">{p.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-600 dark:text-ink-300">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
